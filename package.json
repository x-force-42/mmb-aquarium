{
  "name": "mr-meeseeks-aquarium",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "A playful PixiJS aquarium where Meeseeks reflect external system state.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "pretest:e2e": "playwright install chromium",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "test:e2e:coverage": "cross-env COVERAGE=1 playwright test",
    "test:coverage": "npm run test:unit:coverage && npm run test:e2e:coverage",
    "test": "npm run test:unit && npm run test:e2e"
  },
  "dependencies": {
    "pixi.js": "^7.4.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/node": "^20.12.0",
    "@vitest/coverage-v8": "^1.6.0",
    "cross-env": "^7.0.3",
    "happy-dom": "^14.10.0",
    "monocart-reporter": "^2.9.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.6.0"
  }
}
