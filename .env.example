# Mr. Meeseeks Aquarium — runtime tunables.
# Copy to `.env` (or `.env.local`) and tweak. Vite exposes anything prefixed
# with `VITE_` to client code via `import.meta.env.VITE_*`.
# Every audio value below has a documented default in `src/audio-config.ts`;
# the parser falls back to the default if a var is missing or malformed.

# --- Transport ---------------------------------------------------------------
# WebSocket URL of the MMB-facing relay. When set, the aquarium boots using
# WebSocketTransport (the manual sim buttons stay in the DOM but no longer
# drive state — wire frames coming through the relay do). Leave unset to
# keep the default SimulatorTransport (buttons-only) experience.
# Local relay default: ws://localhost:8080/ws (see `npm run relay`).
VITE_WS_URL=ws://localhost:8080/ws

# --- Mute / unmute ------------------------------------------------------------
# `true` (default) starts muted with a toggle button next to the counter.
# `false` starts unmuted (handy for video demos).
VITE_AUDIO_DEFAULT_MUTED=true

# --- Voice variants -----------------------------------------------------------
# Comma-separated playbackRate multipliers. Each newborn picks one at random.
# Default below gives one canonical voice + two siblings (lower / higher).
VITE_AUDIO_PITCH_OFFSETS=0.92,1.0,1.08

# --- Birth bursts -------------------------------------------------------------
VITE_AUDIO_BIRTH_BURST_CAP=3
VITE_AUDIO_BIRTH_BURST_WINDOW_MS=400

# --- Cadence (seconds) --------------------------------------------------------
VITE_AUDIO_COOLDOWN_S=2.5
VITE_AUDIO_CHAIN_COOLDOWN_S=4.0
VITE_AUDIO_AMBIENT_TICK_S=2.0
VITE_AUDIO_NEWBORN_LOCK_S=1.5
VITE_AUDIO_RECOVERED_LOCK_S=1.5

# --- Concurrency --------------------------------------------------------------
VITE_AUDIO_CONCURRENT_CAP=4

# --- Volume mix ---------------------------------------------------------------
# Ambient toggle: when false, the per-Meeseeks "consider speaking" tick is
# disabled. Event-driven lines (born, freak, recover, death, critical crossing)
# still play. Persisted user prefs (localStorage `mma-audio-prefs`) override.
VITE_AUDIO_AMBIENT_ENABLED=true

# Master gain applied to every clip. Range [0, 1].
VITE_AUDIO_MASTER_VOLUME=1.0

# Extra gain applied on top of master to *ambient* clips only. Range [0, 1].
# Defaults low so ambient ticks don't dominate the event-driven beats.
VITE_AUDIO_AMBIENT_VOLUME=0.4
